rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // 0. Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role-based access control
    // Note: To avoid recursion and ensure unverified bootstrap admin can work
    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin') ||
        (request.auth.token.email == "nana038mail@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isManager() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'InventoryManager') ||
        isAdmin()
      );
    }

    function isSalesperson() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Salesperson') ||
        isAdmin()
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() >= 1 &&
             data.username is string && data.username.size() >= 1 && data.username.size() <= 64 &&
             data.role in ['Admin', 'Salesperson', 'InventoryManager'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'retail_price', 'stock_quantity']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 128 &&
             data.retail_price is number && data.retail_price >= 0 &&
             data.stock_quantity is number && data.stock_quantity >= 0;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['date', 'total_amount', 'salesperson_id', 'items']) &&
             data.total_amount is number && data.total_amount >= 0 &&
             data.salesperson_id == request.auth.uid &&
             data.items is list && data.items.size() >= 1;
    }

    // ===============================================================
    // Collection Match Blocks
    // ===============================================================

    match /users/{userId} {
      // Allow user to get their own profile during login or if they are admin
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      // Only admins can list all users
      allow list: if isAdmin();
      
      allow create: if (isOwner(userId) && isValidUser(incoming())) || isAdmin();
      allow update: if (isOwner(userId) && incoming().role == existing().role && isValidUser(incoming())) || isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isManager() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isManager() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      // Secure list query
      allow list: if isSignedIn() && (isAdmin() || existing().salesperson_id == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || existing().salesperson_id == request.auth.uid);
      
      allow create: if isSalesperson() && isValidSale(incoming());
      allow update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSalesperson();
    }

    match /suppliers/{supplierId} {
      allow read: if isManager();
      allow write: if isManager();
    }

    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    match /bank_accounts/{accountId} {
      allow read, write: if isAdmin();
    }

    match /saved_reports/{reportId} {
      allow read, write: if isAdmin();
    }

    match /customer_payments/{paymentId} {
      allow read, write: if isSalesperson();
    }

    match /supplier_payments/{paymentId} {
      allow read, write: if isManager();
    }

    match /supplier_invoices/{invoiceId} {
      allow read, write: if isManager();
    }

    match /incidents/{incidentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || existing().createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /incident_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /_connection_test_/{testId} {
      allow read: if true;
    }
  }
}
